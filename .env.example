# AWS S3 Configuration for File Uploads
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=prod-gepp-platform-assets

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/gepp_platform

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256

# Application Configuration
DEBUG=True
LOG_LEVEL=INFO

# ── ESG LINE channel (Messaging API + LIFF) ─────────────────────────────
# All env vars below are ESG-prefixed so the Reward LINE channel can
# coexist with its own (REWARD_LINE_*) without collision.

# ESG channel access token — fallback when an org has no per-row
# line_channel_token in esg_organization_settings. Used to send replies
# / push messages from the LINE webhook handler.
# The unprefixed LINE_CHANNEL_ACCESS_TOKEN is still accepted for
# backward compat but the ESG_-prefixed name is preferred.
ESG_LINE_CHANNEL_ACCESS_TOKEN=your_esg_line_channel_access_token_here

# ESG channel secret — used to verify webhook X-Line-Signature
# (HMAC-SHA256). Per-org secret in esg_organization_settings.line_channel_secret
# takes precedence; this env var is the fallback. Pairs with
# ESG_LINE_CHANNEL_ACCESS_TOKEN above. Backward compat: LINE_SECRET.
ESG_LINE_SECRET=your_esg_line_channel_secret_here

# LINE Login channel ID for the ESG LIFF (the numeric prefix of the
# LIFF ID, e.g. 2009993849 for LIFF 2009993849-GpYCVVmc). The
# /api/auth/liff endpoint calls LINE's verify endpoint with the user's
# access token and rejects it if `client_id` doesn't match this value —
# stops Reward-LIFF tokens from authenticating into ESG.
# Backward compat: LINE_LOGIN_CHANNEL_ID.
ESG_LINE_LOGIN_CHANNEL_ID=your_esg_line_login_channel_id_here